# ─── Backend ──────────────────────────────────────────────────────────────────
# Local development: point to the Uvicorn server
# Production: set the live Render.com URL in Vercel project settings
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ─── Clerk Authentication ─────────────────────────────────────────────────────
# Auth is optional — app works in anonymous mode if this key is missing.
# Get your key from: https://dashboard.clerk.com → API Keys
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=