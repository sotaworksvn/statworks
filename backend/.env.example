# =============================================================================
# SOTA StatWorks — Environment Variables
# =============================================================================
# Copy this file: cp .env.example .env
# Then fill in the values below.
# NEVER commit .env to git — it is listed in .gitignore.
# =============================================================================

# ---------------------------------------------------------------------------
# Dev Mode (set to "false" in production / Render)
# ---------------------------------------------------------------------------
DEV_MODE=true

# ---------------------------------------------------------------------------
# OpenAI API Keys (required in production, optional in dev mode)
# 4 accounts for key rotation. At least one must be set in production.
# ---------------------------------------------------------------------------
OPENAI_API_KEY_1=
OPENAI_API_KEY_2=
OPENAI_API_KEY_3=
OPENAI_API_KEY_4=

# ---------------------------------------------------------------------------
# CORS Origin
# "*" for local development, exact Vercel URL for production.
# Example: https://sota-statworks.vercel.app
# ---------------------------------------------------------------------------
CORS_ORIGIN=*

# ---------------------------------------------------------------------------
# Supabase — Metadata Persistence (optional, graceful degradation)
# Get these from: Supabase Dashboard → Project Settings → API
# ---------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ---------------------------------------------------------------------------
# Cloudflare R2 — Object Storage (optional, graceful degradation)
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ---------------------------------------------------------------------------
# Clerk — Authentication (optional, graceful degradation)
# Get these from: Clerk Dashboard → API Keys
# CLERK_SECRET_KEY is backend-only. NEVER put it in frontend code.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY goes in frontend/.env.local (not here).
# ---------------------------------------------------------------------------
CLERK_SECRET_KEY=
